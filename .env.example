# Shared (must be the same value across gateway/tools/delegation)
INTERNAL_SECRET=your-internal-secret-min-32-chars-long
DYNAMIC_WEBHOOK_SECRET=whsec_...
DYNAMIC_ENVIRONMENT_ID=env_...

# Gateway
JWT_SECRET=your-secret-key-min-32-chars-long
GATEWAY_PORT=3000
AGENT_WS_URL=ws://agent:18789
AGENT_RESPONSE_TIMEOUT_MS=120000
EXECUTION_TOKEN_TTL_SECONDS=300
OPENCLAW_GATEWAY_TOKEN=your-openclaw-token

# Agent
ANTHROPIC_API_KEY=sk-ant-...

# Tools
TOOLS_PORT=4000
BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/XPQP0Pta87jBaH6Y1_jKY
CHAIN_NAME=base
# MCP-backed strategy deployment (required)
# tools executes this command over stdio.
# For docker-compose, make sure RAINDEX_MCP_HOST_PATH points to a built raindex-mcp checkout.
RAINDEX_MCP_HOST_PATH=./services/raindex-mcp
RAINDEX_MCP_COMMAND=node
RAINDEX_MCP_ARGS=["/app/raindex-mcp/dist/index.js"]
RAINDEX_MCP_CWD=/app/raindex-mcp
# Set exactly one of these settings inputs (URL recommended):
RAINDEX_SETTINGS_URL=https://raw.githubusercontent.com/rainlanguage/rain.strategies/2c8192e9137736507041ebff820b0e7b5b29f0d2/settings.yaml
RAINDEX_SETTINGS_PATH=
RAINDEX_SETTINGS_YAML=
RAINDEX_REGISTRY_URL=https://raw.githubusercontent.com/rainlanguage/rain.strategies/2c8192e9137736507041ebff820b0e7b5b29f0d2/registry
# Enable merged registry (official + local strategies/registry entries)
CUSTOM_STRATEGIES_DIR=./strategies

# Delegation service
DELEGATION_ENCRYPTION_KEY=your-delegation-encryption-key
DYNAMIC_DELEGATION_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----
DYNAMIC_ADMIN_KEY=dyn_admin_...
DELEGATION_TTL_MS=86400000

# Gateway CORS (comma-separated origins)
CORS_ORIGIN=http://localhost:5173

# Test Site
PUBLIC_GATEWAY_URL=http://localhost:3000
PUBLIC_BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/XPQP0Pta87jBaH6Y1_jKY

# Fly.io (CI/CD)
# Set FLY_API_TOKEN as a GitHub Actions secret.
# Generate with: fly tokens create deploy

# npm (publishing)
# NPM_TOKEN=...
