# Gateway
JWT_SECRET=your-secret-key-min-32-chars-long
GATEWAY_PORT=3000
AGENT_WS_URL=ws://agent:18789
OPENCLAW_GATEWAY_TOKEN=your-openclaw-token

# Agent
ANTHROPIC_API_KEY=sk-ant-...

# Tools
TOOLS_PORT=4000
BASE_RPC_URL=https://mainnet.base.org
CHAIN_NAME=base
EXECUTOR_PRIVATE_KEY=0x...
ALLOWED_SUBGRAPHS=raindex-base,uniswap-v3-base
ORDERBOOK_API_URL=http://albion.internal:8000
ORDERBOOK_API_KEY=${REST_API_KEY}
ORDERBOOK_API_SECRET=${REST_API_SECRET}

# Rest API
REGISTRY_URL=https://raw.githubusercontent.com/rainlanguage/rain.strategies/main/registry
DATABASE_URL=sqlite:///mnt/data/st0x-rest-api/st0x.db
REST_API_KEY=your-api-key-id
REST_API_SECRET=your-api-secret

# Gateway CORS (comma-separated origins)
CORS_ORIGIN=http://localhost:5173

# Test Site
PUBLIC_GATEWAY_URL=http://localhost:3000

# Fly.io (CI/CD)
# Set FLY_API_TOKEN as a GitHub Actions secret.
# Generate with: fly tokens create deploy

# npm (publishing)
# NPM_TOKEN=...
