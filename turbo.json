{
	"$schema": "https://turbo.build/schema.json",
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"env": ["PUBLIC_GATEWAY_URL", "CORS_ORIGIN"],
			"outputs": ["dist/**"]
		},
		"check": {
			"dependsOn": ["^build"]
		},
		"lint": {},
		"test:run": {
			"dependsOn": ["^build"]
		},
		"dev": {
			"cache": false,
			"persistent": true
		}
	}
}
