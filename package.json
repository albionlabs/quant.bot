{
	"name": "quant-bot",
	"version": "0.0.1",
	"type": "module",
	"private": true,
	"scripts": {
		"dev": "tsx watch src/index.ts",
		"start": "node dist/index.js",
		"build": "tsc",
		"check": "tsc --noEmit",
		"lint": "eslint . && prettier --check .",
		"format": "prettier --write .",
		"test": "vitest",
		"test:run": "vitest run"
	},
	"engines": {
		"node": ">=22.0.0"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@types/node": "^25.3.0",
		"eslint": "^10.0.2",
		"eslint-config-prettier": "^10.1.8",
		"prettier": "^3.8.1",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.56.1",
		"vitest": "^4.0.18"
	}
}
