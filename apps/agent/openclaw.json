{
	"tools": {
		"loopDetection": {
			"enabled": true,
			"historySize": 30,
			"warningThreshold": 8,
			"criticalThreshold": 15,
			"globalCircuitBreakerThreshold": 25,
			"detectors": {
				"genericRepeat": true,
				"knownPollNoProgress": true,
				"pingPong": true
			}
		}
	},
	"gateway": {
		"mode": "local",
		"port": 18790,
		"bind": "loopback",
		"auth": {
			"mode": "token"
		},
		"controlUi": {
			"enabled": false
		},
		"http": {
			"endpoints": {
				"chatCompletions": {
					"enabled": true
				}
			}
		}
	},
	"agents": {
		"defaults": {
			"workspace": "/app/workspace",
			"model": "anthropic/claude-sonnet-4-6",
			"contextPruning": {
				"mode": "cache-ttl",
				"ttl": "3m",
				"keepLastAssistants": 2,
				"softTrimRatio": 0.15,
				"hardClearRatio": 0.3,
				"softTrim": {
					"maxChars": 2500,
					"headChars": 1000,
					"tailChars": 1000
				},
				"hardClear": {
					"enabled": true,
					"placeholder": "[Tool result cleared — re-run if needed]"
				}
			},
			"heartbeat": {
				"every": "55m"
			}
		}
	}
}
